

# .env
# Place this file at the root of your project (same level as package.json).
# Never commit this file — add .env to your .gitignore.
#
# This is the ONLY variable you need.
# It's your Google Apps Script deployment URL.
# Both the contact form and CV download tracker use this same URL.
#
# How to get it:
#   1. Open your Google Sheet
#   2. Extensions → Apps Script → paste the doPost() script
#   3. Deploy → New deployment → Web app
#      → Execute as: Me
#      → Who has access: Anyone
#      → Deploy
#   4. Copy the URL and paste it below.

VITE_GOOGLE_SHEET_WEBHOOK=https://script.google.com/macros/s/AKfycbxQmZbM6bh0-B15POUFoIAxHlbgaM-fd73HJbvK-DOsi-LyVClwRQmpddXkniLB2Y8O/exec