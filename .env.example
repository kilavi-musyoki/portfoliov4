# ─────────────────────────────────────────────────────────────────────────────
# Silicon Soul — Environment Variables Template
# Copy this file to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend (Vercel serverless) ───────────────────────────────────────────────

# Google Apps Script Web App URL — receives contact form + CV download events.
# Get it: your Google Sheet → Extensions → Apps Script → Deploy → New deployment
GOOGLE_SHEET_WEBHOOK=YOUR_GOOGLE_APPS_SCRIPT_URL

# Cloudflare Turnstile — SECRET key (backend only, never use VITE_ prefix)
# Get it: dash.cloudflare.com → Turnstile → your site → Secret Key
TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET_KEY

# ── Frontend (bundled by Vite, safe to expose) ────────────────────────────────

# Cloudflare Turnstile — SITE key (public, shown in the browser widget)
# Get it: dash.cloudflare.com → Turnstile → your site → Site Key
VITE_TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE_KEY

# Gmail SMTP credentials (used by /api/contact for email delivery)
# Get it: Google Account → Security → App Passwords → create one for "Mail"
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=YOUR_GMAIL_APP_PASSWORD

# Recipient for contact form emails (defaults to your main email if unset)
CONTACT_RECIPIENT=your-email@gmail.com

# ── Optional ──────────────────────────────────────────────────────────────────

# If your Vercel backend URL differs from the frontend domain, set this.
# Leave blank when frontend and API are on the same Vercel project.
# VITE_API_BASE_URL=https://my-backend-app.vercel.app

# Hire-me status (shown in the nav bar). Defaults shown below.
# STATUS_AVAILABLE=true
# STATUS_SEEKING=Industrial Attachment
# STATUS_UNTIL=May 2026
